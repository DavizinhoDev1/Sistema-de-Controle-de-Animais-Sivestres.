#include <stdio.h>
#include <stdlib.h>
#include <string.h>

// 1. Definição da Estrutura
typedef struct {
    int id;
    char nome[50];
    char especie[30];
    int idade;
} Animal;

// 2. Função para salvar no "Banco de Dados" (Arquivo)
void salvarNoArquivo() {
    FILE *arquivo = fopen("banco_de_animais.dat", "ab");
    if (arquivo == NULL) {
        printf("\nErro ao abrir o arquivo!");
        return;
    }

    Animal a;
    printf("\n--- NOVO CADASTRO ---\n");
    printf("ID: ");
    scanf("%d", &a.id);
    getchar(); // Limpa o buffer

    printf("Nome: ");
    fgets(a.nome, 50, stdin);
    a.nome[strcspn(a.nome, "\n")] = 0;

    printf("Especie: ");
    fgets(a.especie, 30, stdin);
    a.especie[strcspn(a.especie, "\n")] = 0;

    printf("Idade: ");
    scanf("%d", &a.idade);

    fwrite(&a, sizeof(Animal), 1, arquivo);
    fclose(arquivo);
    printf("\nAnimal salvo com sucesso!");
}

// 3. Função para ler do "Banco de Dados"
void listarAnimais() {
    FILE *arquivo = fopen("banco_de_animais.dat", "rb"); // "rb" = Read Binary (Ler)
    if (arquivo == NULL) {
        printf("\nO banco de dados esta vazio ou nao existe.\n");
        return;
    }

    Animal a;
    printf("\n--- ANIMAIS CADASTRADOS ---\n");
    // fread retorna 1 enquanto conseguir ler um registro completo
    while (fread(&a, sizeof(Animal), 1, arquivo)) {
        printf("ID: %d | Nome: %-15s | Especie: %-10s | Idade: %d anos\n", 
                a.id, a.nome, a.especie, a.idade);
    }
    fclose(arquivo);
}

// 4. Programa Principal com Menu
int main() {
    int opcao;

    do {
        printf("\n==============================");
        printf("\n   SISTEMA DE PET SHOP v1.0");
        printf("\n==============================");
        printf("\n1. Cadastrar Animal");
        printf("\n2. Listar Todos");
        printf("\n0. Sair");
        printf("\nEscolha uma opcao: ");
        scanf("%d", &opcao);

        switch(opcao) {
            case 1: salvarNoArquivo(); break;
            case 2: listarAnimais(); break;
            case 0: printf("\nEncerrando sistema...\n"); break;
            default: printf("\nOpcao invalida!\n");
        }
    } while(opcao != 0);

    return 0;
}
